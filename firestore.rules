rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper
    function isLoggedIn() { return request.auth != null; }
    function isAdmin() { return request.auth.token.admin == true; }
    
    // Public read
    match /products/{product} { allow read: if true; allow write: if isAdmin(); }
    match /videos/{video} { allow read: if true; allow create: if isLoggedIn(); allow update: if isAdmin(); }
    
    // Orders: only authenticated users can create
    match /orders/{order} {
      allow create: if isLoggedIn();
      allow read: if isAdmin() || request.auth.uid == resource.data.userId;
    }
    
    // User private data
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
  }
}
